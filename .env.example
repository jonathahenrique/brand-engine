# Brand Engine — API Keys para geração de imagens com IA
# Copie este arquivo para .env.local e preencha com suas chaves

# OpenAI — GPT Image 1 Mini (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# OpenRouter — Gemini via OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Google AI — Gemini direct API (https://aistudio.google.com/apikey)
GOOGLE_AI_API_KEY=
